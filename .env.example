# SMTP settings for nodemailer (contact form emails)
# Copy this file to .env.local and fill in the real values

# SMTP server host (e.g. smtp.gmail.com, smtp.yandex.ru, smtp.mail.ru)
SMTP_HOST=smtp.example.com

# SMTP port: 587 for STARTTLS, 465 for SSL/TLS, 25 for plain
SMTP_PORT=587

# SMTP authentication — the mailbox that sends the notification
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password

# The email address that will receive contact form submissions
# (can be the same as SMTP_USER or a different inbox)
CONTACT_EMAIL=info@yourcompany.com
